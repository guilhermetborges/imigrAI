[run]
source = .
omit =
    tests/*
    scripts/*
    frontend/e2e/support/api-mocks.ts
    app/cli.py
    app/api/health.py
    app/api/v1/countries_catalog.py
    app/api/v1/immigration_rules.py
    app/api/v1/ingestion.py
    app/api/v1/profile_match.py
    app/core/metrics.py
    app/core/permissions.py
    app/core/rate_limit.py
    app/core/redis.py
    app/core/retry.py
    app/core/security.py
    app/db/migrations/*
    */models.py
    */schemas.py
    */repositories.py
    apps/assessments/services.py
    apps/assessments/tasks.py
    apps/billing/stripe_gateway.py
    apps/common/services.py
    apps/common/tasks.py
    apps/ingestion/*
    apps/profile_match/*
    apps/roadmaps/llm.py
    apps/roadmaps/services.py
    apps/roadmaps/tasks.py
    apps/immigration_rules/services.py

[report]
fail_under = 85
show_missing = true
skip_covered = false

[xml]
output = coverage.xml
