APP_ENV=dev
APP_NAME=imigrai-api
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG
TIMEZONE=UTC

API_V1_PREFIX=/api/v1

POSTGRES_DB=imigrai
POSTGRES_USER=imigrai
POSTGRES_PASSWORD=imigrai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://imigrai:imigrai@postgres:5432/imigrai
ALEMBIC_DATABASE_URL=postgresql+psycopg://imigrai:imigrai@postgres:5432/imigrai

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
SCORE_TASK_MAX_RETRIES=3
SCORE_TASK_SOFT_TIME_LIMIT_SECONDS=25
SCORE_TASK_TIME_LIMIT_SECONDS=35
ROADMAP_TASK_MAX_RETRIES=3
ROADMAP_TASK_SOFT_TIME_LIMIT_SECONDS=90
ROADMAP_TASK_TIME_LIMIT_SECONDS=120

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

SCORE_ALGORITHM_VERSION=score-engine-v1
ROADMAP_SCHEMA_VERSION=roadmap.v1

LLM_PROVIDER=openai
LLM_TIMEOUT_SECONDS=45
LLM_TEMPERATURE=0.1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
PRO_ROADMAP_FEATURE_KEY=roadmap.pro
ASSESSMENT_FEATURE_KEY=assessments.monthly
PROCESSING_PRIORITY_FEATURE_KEY=processing.priority
HISTORY_EXTENDED_FEATURE_KEY=history.extended
COUNTRY_COMPARISON_FEATURE_KEY=countries.comparison
FREE_ASSESSMENT_MONTHLY_LIMIT=3
FREE_PLAN_CODE=free
FREE_PLAN_NAME=Free
PRO_PLAN_CODE=pro
PRO_PLAN_NAME=Pro Monthly

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
