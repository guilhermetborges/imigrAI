APP_ENV=dev
APP_NAME=imigrai-api
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG
TIMEZONE=UTC

API_V1_PREFIX=/api/v1

POSTGRES_DB=imigrai
POSTGRES_USER=imigrai
POSTGRES_PASSWORD=imigrai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://postgres:Felipe33_2026@db.yqsplzrnobrwjcnhjjap.supabase.co:5432/postgres
ALEMBIC_DATABASE_URL=postgresql+psycopg://postgres:Felipe33_2026@db.yqsplzrnobrwjcnhjjap.supabase.co:5432/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DB_SLOW_QUERY_THRESHOLD_MS=250

REDIS_PASSWORD=change-me-redis-password
REDIS_PASSWORD_URLENCODED=change-me-redis-password-urlencoded
REDIS_URL=redis://:change-me-redis-password-urlencoded@localhost:6379/0
CELERY_BROKER_URL=redis://:change-me-redis-password-urlencoded@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:change-me-redis-password-urlencoded@localhost:6379/1
SCORE_TASK_MAX_RETRIES=3
SCORE_TASK_SOFT_TIME_LIMIT_SECONDS=25
SCORE_TASK_TIME_LIMIT_SECONDS=35
ROADMAP_TASK_MAX_RETRIES=3
ROADMAP_TASK_SOFT_TIME_LIMIT_SECONDS=90
ROADMAP_TASK_TIME_LIMIT_SECONDS=120
INGESTION_TASK_MAX_RETRIES=3
INGESTION_TASK_SOFT_TIME_LIMIT_SECONDS=120
INGESTION_TASK_TIME_LIMIT_SECONDS=180
INGESTION_RETRY_BACKOFF_BASE_SECONDS=2
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
CREATION_RATE_LIMIT_REQUESTS=20
CREATION_RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_FAIL_OPEN=true

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Trace-Id,Stripe-Signature,Idempotency-Key
CORS_ALLOW_CREDENTIALS=true
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
ADMIN_EMAILS=
FORCE_HTTPS_REDIRECT=false
MAX_REQUEST_BODY_BYTES=1048576

SCORE_ALGORITHM_VERSION=score-engine-v1
ROADMAP_SCHEMA_VERSION=roadmap.v1

LLM_PROVIDER=openai
LLM_TIMEOUT_SECONDS=45
LLM_TEMPERATURE=0.1
LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
LLM_CIRCUIT_BREAKER_RECOVERY_SECONDS=120
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
PRO_ROADMAP_FEATURE_KEY=roadmap.pro
ASSESSMENT_FEATURE_KEY=assessments.monthly
PROCESSING_PRIORITY_FEATURE_KEY=processing.priority
HISTORY_EXTENDED_FEATURE_KEY=history.extended
COUNTRY_COMPARISON_FEATURE_KEY=countries.comparison
FREE_ASSESSMENT_MONTHLY_LIMIT=3
FREE_PLAN_CODE=free
FREE_PLAN_NAME=Free
PRO_PLAN_CODE=pro
PRO_PLAN_NAME=Pro Monthly

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

SUPABASE_PROJECT_URL=
SUPABASE_SERVICE_ROLE_KEY=

INGESTION_INTERNAL_TOKEN=change-me-internal-token
INGESTION_USER_AGENT=imigrAI-ingestion-bot/1.0
INGESTION_FETCH_TIMEOUT_SECONDS=40
INGESTION_ENFORCE_ROBOTS=true
INGESTION_BRONZE_BUCKET=immigration-bronze
INGESTION_LOCAL_FALLBACK_DIR=.cache/ingestion
INGESTION_GATEWAY_MAX_RETRIES=3
INGESTION_GATEWAY_BASE_BACKOFF_SECONDS=0.5
INGESTION_QUARANTINE_AFTER_FAILURES=3
INGESTION_QUARANTINE_HOURS=24
